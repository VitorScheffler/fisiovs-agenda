generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  fisioterapeuta
  secretaria
  paciente
}

enum AppointmentCategory {
  avaliacao
  retorno
  tratamento
  pilates
  bloqueado
}

enum AppointmentStatus {
  confirmado
  pendente
  rejeitado
}

enum PatientStatus {
  ativo
  inativo
  alta
}

enum TeamRole {
  Fisioterapeuta
  Secretaria
  Auxiliar
  TI
}

enum TeamStatus {
  ativo
  inativo
  ferias
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String // hash bcrypt
  role      UserRole
  specialty String?
  crefito   String?
  avatar    String?

  // Quando role = paciente, vincula ao registro de paciente
  patientId String?  @unique
  patient   Patient? @relation(fields: [patientId], references: [id])

  // Quando role = fisio/secretaria/admin/TI, vincula ao registro de equipe
  teamMember TeamMember?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Patient {
  id        String        @id @default(cuid())
  name      String
  email     String        @unique
  phone     String
  birthDate DateTime
  cpf       String        @unique
  address   String?
  status    PatientStatus @default(ativo)
  condition String?
  since     String
  notes     String?

  user                User?
  appointments        Appointment[]
  appointmentHistory  AppointmentHistoryEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id        String     @id @default(cuid())
  userId    String?    @unique
  user      User?      @relation(fields: [userId], references: [id])
  name      String
  role      TeamRole
  specialty String?
  crefito   String?
  email     String     @unique
  phone     String
  status    TeamStatus @default(ativo)
  since     String
  initials  String
  color     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id            String              @id @default(cuid())
  date          DateTime // data real do agendamento
  time          String // "08:00"
  durationSlots Int                 @default(1)
  patientId     String?
  patient       Patient?            @relation(fields: [patientId], references: [id])
  patientName   String // snapshot, permite agendamentos sem paciente cadastrado
  category      AppointmentCategory
  note          String?
  status        AppointmentStatus   @default(confirmado)
  historyEntry  AppointmentHistoryEntry?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Configuração global da clínica (horários de atendimento etc.).
// Registro único (singleton): sempre acessado/atualizado via id = "singleton".
model ClinicSettings {
  id                String   @id @default("singleton")
  horarioInicio     String   @default("08:00") // "HH:mm"
  horarioFim        String   @default("18:00") // "HH:mm", "00:00" representa meia-noite
  duracaoConsulta   Int      @default(60) // minutos
  intervaloConsulta Int      @default(15) // minutos
  diasAtendimento   String   @default("1,2,3,4,5,6") // dias da semana (0=Dom..6=Sáb), separados por vírgula

  updatedAt DateTime @updatedAt
}


enum PaymentMethod {
  dinheiro
  pix
  cartao
  convenio
  isento
}

model AppointmentHistoryEntry {
  id            String              @id @default(cuid())
  patientId     String
  patient       Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointmentId String?             @unique
  appointment   Appointment?        @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  date          String // dd/MM/yyyy
  time          String? // "08:00"
  category      AppointmentCategory
  complaint     String? // queixa do dia
  procedure     String? // o que foi feito
  note          String?
  attended      Boolean             @default(true)
  paymentMethod PaymentMethod?
  paid          Boolean             @default(false)
  receiptUrl    String?
  status        AppointmentStatus   @default(confirmado)
}